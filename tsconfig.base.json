{
	"compilerOptions": {
		"rootDir": "./src",
		"strict": true,
		"target": "es2022",
		"module": "Node16",
		"lib": ["ES2022"],
		"moduleResolution": "Node16",
		"sourceMap": true,
		"experimentalDecorators": true,
		"pretty": true,
		"noFallthroughCasesInSwitch": true,
		"noImplicitReturns": true,
		"forceConsistentCasingInFileNames": true,
		"noEmit": true
	}
}
